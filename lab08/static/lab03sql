--6
create tablespace TS1
datafile 'ts_datafile3.dbf'
size 50m
autoextend on next 10m
maxsize unlimited;

create temporary tablespace TS1TEMP
tempfile 'ts_dataTEMPfile3.dbf'
size 20m
autoextend on next 10m
maxsize unlimited;

create role RL1;

grant create session to RL1;
grant create table, drop any table to RL1;
grant create view, drop any view to RL1;
grant create procedure, drop any procedure to RL1;
grant select any dictionary to RL1;

create profile PF1 limit
password_life_time 180
sessions_per_user 3
failed_login_attempts 7
password_lock_time 1
password_reuse_time 10
password_grace_time default
connect_time 180
idle_time 30;

create user U1_FIO_PDB
identified by "1234"
default tablespace TS1
temporary tablespace TS1TEMP
profile PF1
account unlock
quota unlimited on TS1;

grant RL1 to U1_FIO_PDB;

grant create session to U1_FIO_PDB;

